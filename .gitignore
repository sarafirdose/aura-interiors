# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Prisma SQLite database (local only, not for production)
prisma/dev.db
prisma/dev.db-journal

# Large local media assets (too large for GitHub, host on CDN for production)
public/frames/
public/bedroom.mp4
public/bg-video.mp4
public/living.mp4

# Local product images (re-run download_furniture.ts to restore)
public/images/products/
